# Server Configuration
PORT=5000
NODE_ENV=development
TZ=Asia/Kathmandu

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/home-service-platform

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@homeservice.com

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# REDIS CONFIGURATION (Caching Layer)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# KAFKA CONFIGURATION (Event Bus)
# ============================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=home-service-platform
KAFKA_CONNECTION_TIMEOUT=3000
KAFKA_REQUEST_TIMEOUT=30000
KAFKA_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================
# General API rate limiting (500 requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# Auth endpoints rate limiting (100 attempts per 15 minutes for development)
# NOTE: Use stricter limits (e.g., 10) in production
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=100
